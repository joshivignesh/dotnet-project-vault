{
  "OpenWeatherMap": {
    "ApiKey": "YOUR_API_KEY_HERE",
    "BaseUrl": "https://api.openweathermap.org/data/2.5",
    "Units": "metric"
  },
  "Cache": {
    "WeatherDurationMinutes": 10,
    "ForecastDurationMinutes": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
